#include <iostream>
using namespace std;

class solution{
    public:
    vector<int>
    twoSum(vector<int> &nums, int target)
    for (int i=0;i<nums.size();i++){
        for  (int j = 0; j < nums.size(); j++){
        if (nums[j]=target - nums[i]){
            return {i,j};
        }
        }
    }
     
}